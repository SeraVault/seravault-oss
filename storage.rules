rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Files stored under /files/{ownerId}/{fileId} (flat) or /files/{ownerId}/{fileId}/... (nested)
    // Enforce both storage path ownership and Firestore document sharing rules
    match /files/{ownerId}/{fileId} {
      // Read: any authenticated user. The storagePath is only obtainable from the
      // Firestore file doc, which already enforces sharedWith — security is there.
      allow read: if request.auth != null;
      allow write, create, delete: if request.auth != null && request.auth.uid == ownerId;
    }

    match /files/{ownerId}/{fileId}/{rest=**} {
      allow read: if request.auth != null;
      allow write, create, delete: if request.auth != null && request.auth.uid == ownerId;
    }
    
    // Deny all other storage access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
