{
  "name": "seravault-firebase",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:firebase-dev": "vite --mode development",
    "dev:demo": "vite --mode demo",
    "dev:supabase": "vite --mode supabase",
    "deploy:supabase": "./deploy-supabase.sh",
    "deploy:supabase:db": "./deploy-supabase.sh db",
    "deploy:supabase:functions": "./deploy-supabase.sh functions",
    "deploy:supabase:secrets": "./deploy-supabase.sh secrets",
    "deploy:supabase:app-build": "./deploy-supabase.sh app-build",
    "deploy:cloudflare": "./deploy-cloudflare.sh all",
    "deploy:cloudflare:app": "./deploy-cloudflare.sh app",
    "build:cloudflare": "./deploy-cloudflare.sh build",
    "android:setup": "./scripts/setup-android-avd.sh",
    "android:emulator": "./scripts/start-android-emulator.sh",
    "android:emulator:cold": "./scripts/start-android-emulator.sh --cold",
    "android:emulator:pixel7": "AVD=Pixel_7_API_34 ./scripts/start-android-emulator.sh",
    "android:emulator:pixel7:cold": "AVD=Pixel_7_API_34 ./scripts/start-android-emulator.sh --cold",
    "build": "node scripts/generate-sw-config.cjs && node scripts/increment-sw-version.cjs && tsc -b && vite build",
    "build:demo": "vite build --mode demo --outDir dist-demo",
    "build:deploy": "node scripts/generate-sw-config.cjs && node scripts/increment-sw-version.cjs && vite build",
    "build:ios": "node scripts/generate-sw-config.cjs && node scripts/increment-sw-version.cjs && VITE_PLATFORM=ios vite build --outDir dist-ios",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:run && npm run test:e2e",
    "clear:firebase": "node scripts/clear-firebase-data.cjs",
    "build:extension": "cd extension && npm install && npm run build",
    "build:extension:watch": "cd extension && npm install && npm run build:watch",
    "build:oss-release": "./scripts/build-oss-release.sh"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.1",
    "@mui/material": "^7.3.1",
    "@noble/ciphers": "^1.3.0",
    "@noble/hashes": "^1.8.0",
    "@noble/post-quantum": "^0.4.1",
    "@supabase/supabase-js": "^2.89.0",
    "@types/react-router-dom": "^5.3.3",
    "@uiw/react-md-editor": "^4.0.8",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dexie": "^3.2.4",
    "dompurify": "^3.3.1",
    "file-saver": "^2.0.5",
    "firebase": "^12.1.0",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0",
    "i18next": "^25.4.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "jszip": "^3.10.1",
    "quill": "^2.0.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^15.7.2",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "react-window": "^2.2.3",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/crypto-js": "^4.2.2",
    "@types/dompurify": "^3.0.5",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "^3.2.4",
    "baseline-browser-mapping": "^2.8.28",
    "dotenv": "^17.2.3",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "supabase": "^2.101.0",
    "terser": "^5.46.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^3.2.4",
    "workbox-window": "^7.3.0"
  },
  "license": "GPL-3.0-or-later"
}
